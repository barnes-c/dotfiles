{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70"
  },
  "permissions": {
    "allow": [
      "Bash(~/.local/pipx/venvs/python-landbclient/bin/python -m flake8 landbclient/tests/unit/test_client.py landbclient/tests/unit/fixtures.py)",
      "Bash(~/.local/pipx/venvs/python-landbclient/bin/python -m pip install flake8 flake8-docstrings hacking -q)",
      "Bash(docker buildx imagetools inspect node:22-alpine)",
      "Bash(docker manifest inspect node:22-alpine)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(go build:*)",
      "Bash(go fmt:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(gofmt:*)",
      "Bash(goimports:*)",
      "Bash(grep:*)",
      "Bash(kubectl get svc -n sealed-secrets)",
      "Bash(kubeseal --version)",
      "Read(//Users/barnes-c/Code/**)",
      "Read(//Users/barnes-c/Code/gitops-repo/**)",
      "Read(//Users/barnes-c/go/**)",
      "WebFetch(domain:gitlab.cern.ch)",
      "WebFetch(domain:proxy.golang.org)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "Bash(go mod *)",
      "Bash(make fmt *)",
      "Bash(make lint *)",
      "Bash(make build *)",
      "Bash(make test *)",
      "Bash(go test *)",
      "Bash(yamllint -c .github/.yamllint .)",
      "Bash(echo \"\\(yamllint exit: $?\\)\")",
      "Bash(make check *)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(go get *)",
      "Bash(go run *)",
      "Bash(go list *)",
      "Bash(go vet *)",
      "Bash(gofmt -l .)",
      "Bash(make)",
      "Bash(curl -s http://localhost:10054/metrics)",
      "Bash(yamllint .github/workflows/ci.yml)",
      "Bash(podman compose *)",
      "Bash(yamllint examples/k8s/*.yaml)",
      "Bash(kubeconform -strict -ignore-missing-schemas examples/k8s/)",
      "Bash(yamllint examples/k8s/*.yaml examples/sysconfig/* examples/systemd/*)",
      "WebFetch(domain:packages.debian.org)",
      "WebFetch(domain:opentelemetry.io)",
      "Bash(yamllint -c .github/.yamllint internal/otel/testdata/)",
      "Bash(goreleaser check *)",
      "WebFetch(domain:goreleaser.com)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.env)",
      "Read(~/.netrc)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/**)",
      "Read(~/.kube/**)",
      "Bash(git commit:*)",
      "Skill(update-config:*)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "~/.puppetlabs",
      "~/go",
      "~/Code"
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "gitlab.cern.ch",
        "*.claude.com",
        "*.anthropic.com",
        "gitlab.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "pypi.org",
        "files.pythonhosted.org",
        "golang.org",
        "go.dev",
        "proxy.golang.org",
        "sum.golang.org",
        "*.googlesource.com",
        "gopkg.in",
        "opendev.org",
        "*.opendev.org",
        "openstack.org",
        "*.openstack.org",
        "192.168.1.10",
        "192.168.1.11",
        "192.168.1.12"
      ]
    }
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "refreshInterval": 60
  },
  "awaySummaryEnabled": false,
  "fileCheckpointingEnabled": false,
  "telemetry": false,
  "model": "opus"
}
