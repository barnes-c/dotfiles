Host github.com
    HostName github.com
    AddKeysToAgent yes
    User git
    IdentityFile ~/.ssh/personal
    IdentitiesOnly yes

Host gitlab.cern.ch
    HostName gitlab.cern.ch
    User git
    Port 7999
    IdentityFile ~/.ssh/cern

# Any other root login on a CERN host: don't forward personal krb tickets
Match Host *.cern.ch User root
    GSSAPIDelegateCredentials no
    ForwardAgent no
    PubkeyAuthentication yes

Host !lxtunnel.cern.ch !lxplus.cern.ch !aiadm.cern.ch !ciadm.cern.ch !lxtunnel !lxplus !aiadm !ciadm !gitlab.cern.ch
    User chbarnes
    PreferredAuthentications gssapi-with-mic,keyboard-interactive,password
    GSSAPIDelegateCredentials yes
    GSSAPIAuthentication yes
    IdentitiesOnly yes
    ServerAliveInterval 30

Host lxtunnel.cern.ch ciadm.cern.ch lxplus.cern.ch aiadm.cern.ch lxtunnel ciadm lxplus aiadm
    User chbarnes
    # if your client is configured for Kerberos
    GSSAPIDelegateCredentials yes
    GSSAPIAuthentication yes
    # SOCKS5 proxy for web, see below
    DynamicForward 8090
    ExitOnForwardFailure no
