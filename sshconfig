Host github.com
    HostName github.com
    AddKeysToAgent yes
    User git
    IdentityFile ~/.ssh/personal
    IdentitiesOnly yes

Host gitlab.cern.ch
    HostName gitlab.cern.ch
    User git
    Port 7999
    IdentityFile ~/.ssh/cern

Host cci-*.cern.ch
    User root

Host *.cern.ch !lxplus.cern.ch !ciadm.cern.ch !ciadm !aitnadm.cern.ch !aiadm.cern.ch !lxplus !aiadm !aitnadm !gitlab.cern.ch !ciadm !ciadm.cern.ch
    User chbarnes
    ProxyJump lxplus.cern.ch
    PreferredAuthentications gssapi-with-mic,keyboard-interactive,password
    GSSAPIDelegateCredentials yes
    GSSAPIAuthentication yes
    IdentitiesOnly yes
    ServerAliveInterval 30

Host ciadm.cern.ch ciadm lxtunnel.cern.ch lxplus.cern.ch aiadm.cern.ch lxtunnel lxplus aiadm
    User chbarnes
    # if your client is configured for Kerberos
    GSSAPIDelegateCredentials yes
    GSSAPIAuthentication yes
    # SOCKS5 proxy for web, see below
    DynamicForward 8090
    ExitOnForwardFailure no

 Host cci-neutron-poc-a12
    ProxyJump ciadm
    User root
    GSSAPIAuthentication yes
    GSSAPIDelegateCredentials yes
